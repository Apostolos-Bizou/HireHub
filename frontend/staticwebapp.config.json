{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/images/*", "*.css", "*.js", "*.png", "*.jpg", "*.svg", "*.ico", "*.woff2"]
  },
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous"]
    }
  ],
  "globalHeaders": {
    "Cache-Control": "no-cache"
  },
  "mimeTypes": {
    ".js": "application/javascript",
    ".mjs": "application/javascript"
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  },
  "forwardingGateway": {
    "requiredHeaders": {},
    "allowedForwardedHosts": ["hirehub-api.azurewebsites.net"]
  }
}
